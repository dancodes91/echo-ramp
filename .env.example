# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database & cache
DATABASE_URL=postgresql://echo:echo@localhost:5432/echo_ramp
REDIS_URL=redis://localhost:6379

# Auth
HMAC_SECRET_SALT=change-me-in-production
JWT_SECRET=
DEV_SKIP_HMAC=true

# Session state machine — allow quote/order shortcuts in test/dev (false in production)
RELAX_STATE_GUARDS=false

# Fiat rails (BCB under Lydiam programme)
FIAT_PROVIDER=bcb
BCB_BASE_URL=https://api.uat.bcb.group
BCB_CLIENT_ID=
BCB_CLIENT_SECRET=
BCB_ACCOUNT_ID=
BCB_WEBHOOK_SECRET=

# Ramp/FX routing via Lydiam programme (mandatory v1.2)
ROUTING_PROVIDER=lydiam
LYDIAM_API_BASE_URL=
LYDIAM_API_KEY=

# Identity & bank aggregators
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
PLAID_CLIENT_ID=
PLAID_SECRET=
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
