# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database & cache
DATABASE_URL=postgresql://echo:echo@localhost:5432/echo_ramp
REDIS_URL=redis://localhost:6379

# Auth
HMAC_SECRET_SALT=change-me-in-production
JWT_SECRET=
DEV_SKIP_HMAC=true

# Ramp/FX routing: ripple_otc | openfx (BVNK is fiat rails only — separate adapter)
ROUTING_PROVIDER=ripple_otc

# Provider credentials (sandbox)
BVNK_API_KEY=
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
CHAINALYSIS_API_KEY=
PLAID_CLIENT_ID=
PLAID_SECRET=
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
